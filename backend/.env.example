PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/pawpalace

# JWT
JWT_SECRET=
JWT_EXPIRE=7d

# Client URL
CLIENT_URL=http://localhost:5173

# Google OAuth (cùng giá trị với VITE_GOOGLE_CLIENT_ID ở frontend)
GOOGLE_CLIENT_ID=

# Email (BREVO SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# VNPay (lấy từ https://sandbox.vnpayment.vn/merchantv2/)
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5000/api/donate/vnpay-return
